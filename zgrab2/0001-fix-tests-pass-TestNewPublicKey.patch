From: jackyzy823 <jackyzy823@gmail.com>
Date: Fri, 24 Apr 2026 16:55:00 +0000
Subject: [PATCH 1/7] fix(tests): pass TestNewPublicKey

`NewPublicKey` requires `*dsa.PublicKey`, however in `rawkey` it returns `*dsaPublicKey`
---
 lib/ssh/keys_test.go | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/lib/ssh/keys_test.go b/lib/ssh/keys_test.go
index 3ae3cad..07a6387 100644
--- a/lib/ssh/keys_test.go
+++ b/lib/ssh/keys_test.go
@@ -20,7 +20,7 @@ import (
 	"strings"
 	"testing"
 
-	_ "github.com/zmap/zcrypto/dsa"
+	"github.com/zmap/zcrypto/dsa"
 	"golang.org/x/crypto/ed25519"
 
 	"github.com/zmap/zgrab2/lib/ssh/testdata"
@@ -31,7 +31,7 @@ func rawKey(pub PublicKey) any {
 	case *rsaPublicKey:
 		return (*rsa.PublicKey)(k)
 	case *dsaPublicKey:
-		return (*dsaPublicKey)(k)
+		return (*dsa.PublicKey)(k)
 	case *ecdsaPublicKey:
 		return (*ecdsa.PublicKey)(k)
 	case ed25519PublicKey:
