%cargo_build
%{cargo_license_summary}
%{cargo_license} > LICENSE.dependencies

%install
%cargo_install
# install shared library
mkdir -p %{buildroot}/%{_libdir}
cp -pav target/release/libboringtun.so %{buildroot}/%{_libdir}/libboringtun.so.%{soversion}
%if %{with static}
cp -pav target/release/libboringtun.a %{buildroot}/%{_libdir}/libboringtun.a
%endif
mkdir -p %{buildroot}/%{_includedir}
cp -pav src/wireguard_ffi.h %{buildroot}/%{_includedir}/wireguard_ffi.h
