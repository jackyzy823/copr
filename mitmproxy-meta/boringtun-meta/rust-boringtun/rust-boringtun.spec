%prep
%autosetup -n %{crate}-%{version} -p1
# Adjust dependencies version
tomcli-set Cargo.toml str dependencies.ring.version 0.17
tomcli-set Cargo.toml str dependencies.x25519-dalek.version 2.0.1
tomcli-set Cargo.toml del dev-dependencies.criterion
tomcli-set Cargo.toml str 'target."cfg(unix)".dependencies.nix.version' 0.26
%cargo_prep
# copy in license file
cp -p %{SOURCE2} .
echo 'fn main(){println!("cargo::rustc-link-arg-cdylib=-Wl,-soname,libboringtun.so.%{soversion}");}' > build.rs

%generate_buildrequires
%cargo_generate_buildrequires

